# Copy this file to .env.local for local development.
# In production, set these in the Vercel project's Environment Variables.

# Required: Resend API key. Generate at https://resend.com/api-keys
RESEND_API_KEY=

# Optional: Override the destination address for design partner applications.
# Defaults to info@getprovidex.com.
# DESIGN_PARTNER_TO_EMAIL=info@getprovidex.com

# Optional: Override the From address. Must be on a Resend-verified domain.
# Use the "Display Name <address@domain>" format for nicer inbox rendering.
# Defaults to "Providex <info@getprovidex.com>".
# DESIGN_PARTNER_FROM_EMAIL=Providex <info@getprovidex.com>
